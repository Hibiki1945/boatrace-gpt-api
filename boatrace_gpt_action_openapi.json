{
  "openapi": "3.1.0",
  "info": {
    "title": "BOAT RACE Official Scraper Action",
    "description": "BOAT RACE公式の出走表、直前情報、3連単オッズ、レース場データを取得し、24場攻略情報と場優先度ルールを統合して返します。",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "https://boatrace-gpt-api.onrender.com",
      "description": "Renderで公開した競艇予想API"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "APIの稼働確認",
        "responses": {
          "200": {
            "description": "稼働中",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "service": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/boatrace/race-data": {
      "get": {
        "operationId": "getBoatraceRaceData",
        "summary": "BOAT RACE公式情報と場別攻略情報を取得する",
        "description": "予想時はinclude_result=false、レース後検証時のみinclude_result=trueにしてください。",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "開催日。YYYYMMDDまたはYYYY-MM-DD。",
            "schema": { "type": "string", "examples": ["20260619"] }
          },
          {
            "name": "place",
            "in": "query",
            "required": true,
            "description": "ボートレース場名または場コード。例: 戸田 / 02。",
            "schema": { "type": "string", "examples": ["戸田"] }
          },
          {
            "name": "race",
            "in": "query",
            "required": true,
            "description": "レース番号。1から12。",
            "schema": { "type": "integer", "minimum": 1, "maximum": 12, "examples": [12] }
          },
          {
            "name": "include_result",
            "in": "query",
            "required": false,
            "description": "レース後検証時のみtrue。予想時はfalse。",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "スクレイピング済みレースデータ",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "データ種別": { "type": "string" },
                    "作成時刻": { "type": "string" },
                    "レース識別": { "type": "object", "properties": {} },
                    "公式取得情報": { "type": "object", "properties": {} },
                    "場別攻略情報": { "type": "object", "properties": {} },
                    "場優先度": { "type": "object", "description": "場ランク、購入判断、日次予算上限比率、購入追加条件、注意事項", "properties": {} },
                    "テンプレート反映メモ": { "type": "object", "properties": {} },
                    "APIメタ": { "type": "object", "properties": {} }
                  }
                }
              }
            }
          },
          "400": { "description": "入力エラー" },
          "401": { "description": "APIキー認証エラー" },
          "500": { "description": "サーバー内部エラー" }
        }
      }
    },
    "/boatrace/prediction": {
      "post": {
        "operationId": "evaluateManualPastedData",
        "summary": "手動貼り付け競艇データを解析・評価する",
        "description": "外部サイトへアクセスせず、ユーザーが手動で貼り付けた展示、平均ST、モーター、選手成績、決まり手だけを解析します。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["venue", "wind", "pasted"],
                "properties": {
                  "venue": {"type": "string", "description": "ボートレース場名。例: 大村"},
                  "wind": {"type": "string", "description": "風区分。例: 向かい風1m"},
                  "f_hold_boats": {
                    "type": "array",
                    "description": "F持ちの艇番。例: [2]",
                    "items": {"type": "integer", "minimum": 1, "maximum": 6}
                  },
                  "pasted": {
                    "type": "object",
                    "required": ["tenji"],
                    "properties": {
                      "tenji": {"type": "string", "description": "展示情報のコピー全文"},
                      "st": {"type": "string", "description": "平均ST表のコピー全文"},
                      "motor": {"type": "string", "description": "モーター表のコピー全文"},
                      "racer": {"type": "string", "description": "枠別選手成績のコピー全文"},
                      "kimari": {"type": "string", "description": "決まり手・逃げシミュレーションのコピー全文"}
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "解析・評価結果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "評価器": {"type": "string"},
                    "順位": {"type": "array", "description": "総合評価順の艇別結果"},
                    "逃げシミュレーション": {"type": "object"},
                    "レース評価コメント": {"type": "string"},
                    "注意": {"type": "array", "items": {"type": "string"}}
                  }
                }
              }
            }
          },
          "400": {"description": "貼り付けデータまたは入力値のエラー"},
          "401": {"description": "APIキー認証エラー"},
          "500": {"description": "サーバー内部エラー"}
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}
