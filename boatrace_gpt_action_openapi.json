{
  "openapi": "3.1.0",
  "info": {
    "title": "BOAT RACE Official Scraper Action",
    "description": "BOAT RACE公式の出走表、直前情報、3連単オッズ、レース場データを取得し、24場攻略情報と統合して返します。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://boatrace-gpt-api.onrender.com",
      "description": "Renderで公開した競艇予想API"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "APIの稼働確認",
        "responses": {
          "200": {
            "description": "稼働中",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "service": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/boatrace/race-data": {
      "get": {
        "operationId": "getBoatraceRaceData",
        "summary": "BOAT RACE公式情報と場別攻略情報を取得する",
        "description": "予想時はinclude_result=false、レース後検証時のみinclude_result=trueにしてください。",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "開催日。YYYYMMDDまたはYYYY-MM-DD。",
            "schema": {
              "type": "string",
              "examples": [
                "20260619"
              ]
            }
          },
          {
            "name": "place",
            "in": "query",
            "required": true,
            "description": "ボートレース場名または場コード。例: 戸田 / 02。",
            "schema": {
              "type": "string",
              "examples": [
                "戸田"
              ]
            }
          },
          {
            "name": "race",
            "in": "query",
            "required": true,
            "description": "レース番号。1から12。",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "examples": [
                12
              ]
            }
          },
          {
            "name": "include_result",
            "in": "query",
            "required": false,
            "description": "レース後検証時のみtrue。予想時はfalse。",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "スクレイピング済みレースデータ",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "データ種別": {
                      "type": "string"
                    },
                    "作成時刻": {
                      "type": "string"
                    },
                    "レース識別": {
                      "type": "object"
                    },
                    "公式取得情報": {
                      "type": "object"
                    },
                    "場別攻略情報": {
                      "type": "object"
                    },
                    "テンプレート反映メモ": {
                      "type": "object"
                    },
                    "APIメタ": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "入力エラー"
          },
          "401": {
            "description": "APIキー認証エラー"
          },
          "500": {
            "description": "サーバー内部エラー"
          }
        }
      }
    },
    "/keiba/race-data": {
      "get": {
        "operationId": "getKeibaRaceSourceData",
        "summary": "JRA公式情報とnetkeiba馬柱を補助取得する",
        "description": "JRA公式URLは必須です。netkeibaはユーザー指定の馬柱URLのみ補助取得します。予想時はinclude_result=falseにしてください。",
        "parameters": [
          {
            "name": "jra_url",
            "in": "query",
            "required": true,
            "description": "JRA公式の出馬表・オッズ・馬場情報等のHTTPS URL。",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "netkeiba_url",
            "in": "query",
            "required": false,
            "description": "補助確認するnetkeibaの馬柱または競走馬ページHTTPS URL。",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "include_result",
            "in": "query",
            "required": false,
            "description": "レース後検証時のみtrue。予想時はfalse。",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JRA公式を主情報とするソース取得結果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "URLまたは入力エラー"
          },
          "401": {
            "description": "APIキー認証エラー"
          }
        }
      }
    },
    "/keiba/evaluate": {
      "post": {
        "operationId": "evaluateKeibaRace",
        "summary": "競馬予想エンジンで全馬を評価する",
        "description": "事前に確認・整理したレース情報と出走馬データを渡し、テンプレートv1.8と学習ログを使って採点します。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "レース情報",
                  "出走馬"
                ],
                "properties": {
                  "レース情報": {
                    "type": "object",
                    "required": [
                      "レース名",
                      "開催日",
                      "開催場",
                      "距離"
                    ],
                    "properties": {
                      "レース名": {
                        "type": "string"
                      },
                      "開催日": {
                        "type": "string",
                        "examples": [
                          "2026-06-21"
                        ]
                      },
                      "開催場": {
                        "type": "string"
                      },
                      "距離": {
                        "type": "string",
                        "examples": [
                          "芝1600m"
                        ]
                      }
                    }
                  },
                  "出走馬": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "馬番",
                        "馬名"
                      ],
                      "properties": {
                        "馬番": {
                          "type": "integer"
                        },
                        "馬名": {
                          "type": "string"
                        },
                        "能力評価": {
                          "type": "number"
                        },
                        "再現性評価": {
                          "type": "number"
                        },
                        "距離適性": {
                          "type": "number"
                        },
                        "開催場適性": {
                          "type": "number"
                        },
                        "展開評価": {
                          "type": "number"
                        },
                        "期待値評価": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "全馬評価、分類、購入判断、推奨三連複・ワイド候補",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "入力データエラー"
          },
          "401": {
            "description": "APIキー認証エラー"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}
